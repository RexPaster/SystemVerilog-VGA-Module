{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Edit top.sv",
            "type": "shell",
            "command": "code ${workspaceFolder}/top.sv"
        },
        {
            "label": "FPGA Image Server",
            "type": "shell",
            "command": "node server.js ${workspaceFolder}/images",
            "options": {
                "cwd": "/opt/fpgaprog"
            },
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "revealProblems": "onProblem",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            }
        },
        {
            "label": "Simulate top.sv",
            "type": "shell",
            "command": "${workspaceFolder}/.devcontainer/makehdl products/top.rtl.json",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "revealProblems": "onProblem",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": {
                "base": "$yosys",
                "owner": "top: simulate",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ]
            }
        },
        {
            "label": "top testbench verification",
            "type": "shell",
            "command": "${workspaceFolder}/.devcontainer/makehdl products/top_tb.vcd",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "revealProblems": "onProblem",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": {
                "base": "$vvp",
                "owner": "top_tb: testbench",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ]
            }
        },
        {
            "label": "top AIG Mapping",
            "type": "shell",
            "command": "${workspaceFolder}/.devcontainer/makehdl products/top.aig.svg",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "echo": true,
